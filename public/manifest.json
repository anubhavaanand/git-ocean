{
  "name": "Git Ocean",
  "short_name": "GitOcean",
  "description": "3D underwater world visualizing GitHub repositories",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#050b18",
  "theme_color": "#06B6D4",
  "icons": [
    { "src": "/icon-192.png", "sizes": "192x192", "type": "image/png" },
    { "src": "/icon-512.png", "sizes": "512x512", "type": "image/png" }
  ],
  "share_target": {
    "action": "/dashboard/chat",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
